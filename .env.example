# === LINE Messaging API（來自你的 Messaging API Channel）===
LINE_CHANNEL_SECRET=在這裡貼上你的Channel_Secret
LINE_CHANNEL_ACCESS_TOKEN=在這裡貼上你的Channel_Access_Token

# === LIFF（來自你剛建立的LIFF App）===
LIFF_ID=在這裡貼上你的LIFF_ID

# === 資料庫（階段1才會用到，先留著）===
DATABASE_URL=postgresql://user:password@localhost:5432/aurobox_line

# === 應用設定 ===
APP_ENV=development
